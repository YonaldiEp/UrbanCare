# ==========================================
# UrbanCare Root .gitignore
# ==========================================

# 1. Node.js & NPM (Frontend & Backend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 2. Environment Variables (Backend & Frontend)
.env
.env.local
.env.development
.env.test
.env.production

# 3. Build Outputs (Frontend Vite)
Frontend/dist/
Frontend/dist-ssr/
*.tsbuildinfo

# 4. OS & System Files
.DS_Store
Thumbs.db

# 5. IDEs & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# 6. Logs & Databases
logs/
*.log
*.sqlite
*.sqlite3